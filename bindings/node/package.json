{
  "name": "@chiff/node",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "./index.cjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "require": "./index.cjs",
      "types": "./index.d.ts"
    }
  },
  "scripts": {
    "build:debug": "cargo build -p chiff-node && node ./scripts/prepare-addon.cjs debug",
    "corpus:stats:node": "npm run build:debug && node ./scripts/corpus-diff-stats.cjs",
    "corpus:stats:bun": "npm run build:debug && bun ./scripts/corpus-diff-stats.cjs",
    "hpatch:report:node": "npm run build:debug && node ./scripts/hpatch-policy-report.cjs",
    "hpatch:report:bun": "npm run build:debug && bun ./scripts/hpatch-policy-report.cjs",
    "hpatch:coalesce:node": "npm run build:debug && node ./scripts/hpatch-native-coalesce-report.cjs",
    "hpatch:coalesce:bun": "npm run build:debug && bun ./scripts/hpatch-native-coalesce-report.cjs",
    "zstd:report:node": "npm run build:debug && node ./scripts/zstd-hdiff-report.cjs",
    "zstd:report:bun": "npm run build:debug && bun ./scripts/zstd-hdiff-report.cjs",
    "test:node": "npm run build:debug && node ./test/detect-format.test.cjs",
    "test:bun": "npm run build:debug && bun ./test/detect-format.test.cjs"
  }
}
